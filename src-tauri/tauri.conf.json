{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dskube",
  "version": "0.2.0",
  "identifier": "kr.kro.dspark.dskube",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "dskube",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "dmg": {
        "background": "../assets/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 210 },
        "applicationFolderPosition": { "x": 480, "y": 210 }
      }
    }
  }
}
